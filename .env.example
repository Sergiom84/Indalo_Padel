# Database
# Este .env va en la raiz del proyecto y lo usa el backend.
DATABASE_URL=postgresql://postgres:password@localhost:5432/indalo_padel
DB_SEARCH_PATH=app,public

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=30d

# Server
PORT=3011
DEMO_MODE=false
CORS_ORIGINS=
PUBLIC_API_BASE_URL=
REQUIRE_EMAIL_VERIFICATION=true

# Email transaccional (registro/verificación/reset)
RESEND_API_KEY=
EMAIL_FROM=

# Google Calendar sync
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_ORGANIZER_EMAIL=
GOOGLE_CALENDAR_SEND_COMMUNITY_INVITES=false
CALENDAR_TIME_ZONE=Europe/Madrid
CALENDAR_SYNC_INTERVAL_MINUTES=2
GOOGLE_EVENT_REMINDER_MINUTES=60

# Firebase Cloud Messaging push
FIREBASE_SERVICE_ACCOUNT_JSON=

# Supabase (optional)
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_AVATAR_MAX_BYTES=524288
REQUIRE_SUPABASE_AUTH=false
